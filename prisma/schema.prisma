generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS (Enterprise Standards)
// ============================================================================
enum Role {
  MEMBER
  RESELLER
  VIP
  CS          
  FINANCE     
  SUPERADMIN  
}

enum KycStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
  BANNED      
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  EXPIRED
  FAILED
  REFUNDED
  CHARGEBACK  
}

enum OrderStatus {
  PENDING
  PROCESSING
  SUCCESS
  ERROR
  PARTIAL
  REFUNDING
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_USER
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MutationType {
  DEPOSIT        
  PAYMENT        
  REFUND         
  COMMISSION     
  WITHDRAWAL     
  ADJUSTMENT     
}

enum PromoType {
  FLAT
  PERCENTAGE
}

enum PaymentType {
  EWALLET
  QRIS
  VIRTUAL_ACCOUNT
  RETAIL
}

// ============================================================================
// 1. SISTEM PENGGUNA & NEXTAUTH (ANTI-ERROR)
// ============================================================================
model User {
  id                String       @id @default(uuid())
  name              String?      // Dibuat opsional karena Google kadang tidak kirim nama
  email             String?      @unique
  emailVerified     DateTime?    // Wajib ada untuk standar NextAuth
  image             String?      // Wajib ada untuk foto profil Google/Facebook
  password          String?   
  phone             String?      @unique
  role              Role         @default(MEMBER)
  
  kycStatus         KycStatus    @default(UNVERIFIED)
  isVerified        Boolean      @default(false)
  idCardNumber      String?      @unique 
  idCardImage       String?
  taxNumber         String?      
  isTwoFactorEnable Boolean      @default(false)
  lastLoginIp       String?
  deviceId          String?      
  
  balance           Decimal      @default(0) @db.Decimal(15, 2)
  points            Int          @default(0)
  
  referralCode      String       @unique @default(uuid())
  referrerId        String?
  referrer          User?        @relation("UserReferral", fields: [referrerId], references: [id])
  referees          User[]       @relation("UserReferral")
  totalCommission   Decimal      @default(0) @db.Decimal(15, 2)
  
  transactions      Transaction[]
  walletLedgers     WalletLedger[] 
  reviews           Review[]     
  supportTickets    SupportTicket[]
  auditLogs         SystemAudit[]  @relation("ActionBy")

  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  accounts          Account[]

  @@index([email, phone, referralCode])
  @@index([kycStatus])
}

// ============================================================================
// 2. DOUBLE-ENTRY LEDGER 
// ============================================================================
model WalletLedger {
  id              String       @id @default(uuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id])
  
  transactionId   String?      @unique 
  type            MutationType
  
  debit           Decimal      @default(0) @db.Decimal(15, 2) 
  credit          Decimal      @default(0) @db.Decimal(15, 2) 
  balanceSnapshot Decimal      @db.Decimal(15, 2) 
  
  description     String
  performedById   String?      
  
  createdAt       DateTime     @default(now())

  @@index([userId, type, createdAt])
}

// ============================================================================
// 3. KATALOG GAME
// ============================================================================
model Category {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  sortOrder   Int       @default(0)
  games       Game[]
}

model Game {
  id            String    @id @default(uuid())
  categoryId    String
  category      Category  @relation(fields: [categoryId], references: [id])
  
  name          String
  slug          String    @unique
  publisher     String?
  thumbnail     String?
  banner        String?
  guideImage    String?
  
  hasServerId   Boolean   @default(false)
  serverOptions Json?     
  
  isActive      Boolean   @default(true)
  isHot         Boolean   @default(false)
  sortOrder     Int       @default(0)

  products      Product[]
  transactions  Transaction[]
  reviews       Review[]

  @@index([slug])
}

model Review {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  gameId        String
  game          Game        @relation(fields: [gameId], references: [id])
  transactionId String      @unique
  
  rating        Int
  comment       String?     @db.Text
  images        Json?        
  
  createdAt     DateTime    @default(now())

  @@index([gameId, rating])
}

// ============================================================================
// 4. PRODUK (DITAMBAH priceSell AGAR COCOK DENGAN KODE TRANSAKSI)
// ============================================================================
model Provider {
  id            String    @id @default(uuid())
  name          String    @unique
  balance       Decimal   @default(0) @db.Decimal(15, 2)
  isActive      Boolean   @default(true)
  
  successRate   Decimal   @default(100) @db.Decimal(5, 2)
  avgLatencyMs  Int       @default(0)
  
  products      Product[]
}

model Product {
  id            String    @id @default(uuid())
  gameId        String
  game          Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  
  providerId    String
  provider      Provider  @relation(fields: [providerId], references: [id])
  sku           String    @unique
  
  name          String
  description   String?
  
  priceModal    Decimal   @db.Decimal(10, 2)
  priceSell     Decimal   @default(0) @db.Decimal(10, 2) // 🔥 Solusi Error Transaksi
  priceMember   Decimal   @db.Decimal(10, 2)
  priceReseller Decimal   @db.Decimal(10, 2)
  priceVip      Decimal   @db.Decimal(10, 2)
  originalPrice Decimal?  @db.Decimal(10, 2)

  isActive      Boolean   @default(true)
  isFlashSale   Boolean   @default(false)
  stock         Int       @default(99999)

  transactions  Transaction[]

  @@index([sku, gameId, isActive])
}

// ============================================================================
// 5. PAYMENT GATEWAY & PROMO
// ============================================================================
model PaymentMethod {
  id          String      @id @default(uuid())
  code        String      @unique
  name        String
  type        PaymentType 
  logo        String?
  
  feeFlat     Decimal     @default(0) @db.Decimal(10, 2)
  feePercent  Decimal     @default(0) @db.Decimal(5, 2)
  
  isActive    Boolean     @default(true)
  sortOrder   Int         @default(0)

  transactions Transaction[]
}

model Promo {
  id            String    @id @default(uuid())
  code          String    @unique
  title         String
  description   String?
  
  type          PromoType    
  value         Decimal   @db.Decimal(10, 2)
  maxDiscount   Decimal?  @db.Decimal(10, 2)
  minTransaction Decimal  @default(0) @db.Decimal(10, 2)
  
  quota         Int       @default(100)
  usedCount     Int       @default(0)
  
  startDate     DateTime  @default(now())
  endDate       DateTime
  isActive      Boolean   @default(true)

  transactions  Transaction[]
}

// ============================================================================
// 6. TRANSAKSI
// ============================================================================
model Transaction {
  id            String    @id @default(uuid())
  invoiceId     String    @unique
  
  userId        String?
  user          User?     @relation(fields: [userId], references: [id])
  
  gameId        String
  game          Game      @relation(fields: [gameId], references: [id])
  productId     String
  product       Product   @relation(fields: [productId], references: [id])
  sku           String
  denomName     String
  
  targetId      String
  zoneId        String?
  targetName    String?
  
  email         String?   // Dibuat opsional agar sinkron
  whatsapp      String?

  paymentId     String
  payment       PaymentMethod @relation(fields: [paymentId], references: [id])
  promoId       String?
  promo         Promo?        @relation(fields: [promoId], references: [id])
  
  priceModal    Decimal   @db.Decimal(10, 2)
  priceSell     Decimal   @db.Decimal(10, 2)
  adminFee      Decimal   @db.Decimal(10, 2)
  taxVat        Decimal   @default(0) @db.Decimal(10, 2) 
  discount      Decimal   @default(0) @db.Decimal(10, 2)
  totalAmount   Decimal   @db.Decimal(10, 2)
  profit        Decimal   @db.Decimal(10, 2)

  paymentStatus PaymentStatus @default(UNPAID)
  orderStatus   OrderStatus   @default(PENDING)
  
  paymentRef    String?
  providerRef   String?
  sn            String?       
  webhookData   Json?

  createdAt     DateTime  @default(now())
  expiredAt     DateTime
  paidAt        DateTime?
  completedAt   DateTime?

  @@index([invoiceId, paymentStatus, orderStatus])
  @@index([targetId])
  @@index([createdAt])
}

// ============================================================================
// 7. CUSTOMER SUPPORT
// ============================================================================
model SupportTicket {
  id            String         @id @default(uuid())
  ticketNumber  String         @unique 
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  
  subject       String
  transactionId String?        
  status        TicketStatus   @default(OPEN)
  priority      TicketPriority @default(MEDIUM)
  
  messages      TicketMessage[]
  
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([userId, status])
}

model TicketMessage {
  id            String         @id @default(uuid())
  ticketId      String
  ticket        SupportTicket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  
  senderId      String         
  message       String         @db.Text
  attachments   Json?          
  
  createdAt     DateTime       @default(now())

  @@index([ticketId])
}

// ============================================================================
// 8. AUDIT TRAIL
// ============================================================================
model SystemAudit {
  id            String       @id @default(uuid())
  actionBy      String       
  admin         User         @relation("ActionBy", fields: [actionBy], references: [id])
  
  action        String       
  entity        String       
  entityId      String       
  
  oldValues     Json?
  newValues     Json?
  
  ipAddress     String?
  userAgent     String?
  
  createdAt     DateTime     @default(now())

  @@index([actionBy, entity, createdAt])
}

// ============================================================================
// 9. SECURITY & NEXTAUTH ACCOUNTS
// ============================================================================
model VerificationToken {
  id         String   @id @default(uuid())
  identifier String   
  token      String   @unique 
  expires    DateTime
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}