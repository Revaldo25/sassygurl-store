# ============================================================================
# SassyGurl Store — .gitignore (Consolidated & Clean)
# ============================================================================

# ── CREDENTIALS & SECRETS (CRITICAL — NEVER COMMIT) ─────────────────────────
.env
.env.*
!.env.example
*.env
appsettings.Development.json
appsettings.*.json
!appsettings.json

# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
**/node_modules/
.pnpm-store/
jspm_packages/

# ── Next.js ──────────────────────────────────────────────────────────────────
.next/
out/

# ── Build outputs ────────────────────────────────────────────────────────────
dist/
build/
*.dist

# ── .NET Build Results ───────────────────────────────────────────────────────
[Dd]ebug/
[Rr]elease/
[Rr]eleases/
**/[Bb]in/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/
artifacts/
.artifacts/

# ── IDE & Editor ─────────────────────────────────────────────────────────────
.vs/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
.idea/
*.swp
*.swo
*~
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs
*.rsuser

# ── OS Generated Files ──────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo

# ── Test & Coverage ──────────────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/
[Tt]est[Rr]esult*/
*.trx

# ── NuGet ────────────────────────────────────────────────────────────────────
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

# ── Caching ──────────────────────────────────────────────────────────────────
.cache/
.parcel-cache/
.eslintcache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/
*.[Cc]ache
!?*.[Cc]ache/
.npm/

# ── Database files ───────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.mdf
*.ldf
*.ndf
healthchecksdb

# ── Runtime ──────────────────────────────────────────────────────────────────
pids/
*.pid
*.seed
*.pid.lock
*.bak

# ── Misc ─────────────────────────────────────────────────────────────────────
*.tgz
.yarn-integrity
*.vsix
mono_crash.*
publish/
tools/cloudflared.exe
.webdev/
tmp/
temp/

# ── Visual Studio Profiler ───────────────────────────────────────────────────
*.psess
*.vsp
*.vspx

# ── ReSharper / DotCover / NCrunch ───────────────────────────────────────────
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user
*.dotCover
_NCrunch_*
.NCrunch_*